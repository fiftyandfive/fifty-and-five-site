# Copy to .env.local for local dev. Set these in Vercel for production.

# Public site URL — used for sitemap, robots, canonical URLs, OG image
NEXT_PUBLIC_SITE_URL=https://fiftyandfive.com

# Calendly inline widget — the full public scheduler URL for the intro call
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/lucasv/30-minute-intro-call

# Plausible analytics — your verified domain. Leave unset to disable tracking.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=fiftyandfive.com

# Resend — transactional email for the contact form.
# Get an API key at https://resend.com and verify your sending domain.
RESEND_API_KEY=
CONTACT_TO_EMAIL=lucas@fiftyandfive.com
CONTACT_FROM_EMAIL=Fifty & Five <hello@fiftyandfive.com>
